{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Routine Timer",
  "version": "0.1.0",
  "identifier": "com.minjun.dailyroutinetimer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      { "label": "main", "url": "index.html#/", "title": "Routine Timer", "titleBarStyle": "Overlay", "hiddenTitle": true, "width": 900, "height": 880, "minWidth": 680, "minHeight": 760 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": { "minimumSystemVersion": "10.14" }
  }
}
